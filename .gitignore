# ========================================
# Root .gitignore
# ========================================

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE / Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.fleet/
.nova/
.zed/

# ========================================
# Backend (Laravel)
# ========================================
backend/vendor/
backend/node_modules/
backend/.env
backend/.env.backup
backend/.env.production
backend/storage/*.key
backend/storage/pail/
backend/public/build/
backend/public/hot
backend/public/storage
backend/.phpunit.cache/
backend/.phpunit.result.cache
backend/.phpactor.json
backend/auth.json
backend/database/database.sqlite
backend/Homestead.json
backend/Homestead.yaml

# ========================================
# Frontend (Vue 3 + Vite)
# ========================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/coverage/
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ========================================
# Logs
# ========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ========================================
# Test & Build Artifacts
# ========================================
*.tsbuildinfo
.eslintcache
*.timestamp-*.mjs

# Python virtual environment (if any)
.venv/
__pycache__/

.env